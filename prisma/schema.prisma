generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoUsuario {
  ADMIN
  PROFESSOR
  ALUNO
}

enum TipoToken {
  ACCESS
  REFRESH
}

enum TipoQuestao {
  MULTIPLA_ESCOLHA
  VERDADEIRO_FALSO
  DISSERTATIVA
}

enum TipoDificuldade {
  FACIL
  MEDIO
  DIFICIL
}

enum StatusNotificacao {
  PENDENTE
  LIDA
  ARQUIVADA
}

enum ResultadoAcesso {
  SUCESSO
  FALHA
}

enum StatusSimuladoLivre {
  EM_ANDAMENTO
  FINALIZADO
}

enum TipoSimulado {
  SIMULADO
  PROVA
  QUESTIONARIO
}

enum StatusSimulado {
  RASCUNHO
  PUBLICADO
  ARQUIVADO
}

enum StatusAplicacao {
  AGENDADA
  EM_ANDAMENTO
  ENCERRADA
}

enum StatusResultado {
  EM_ANDAMENTO
  FINALIZADO
  EXPIRADO
}

enum StatusImportacao {
  PENDENTE
  PROCESSANDO
  CONCLUIDA
  FALHA
}

enum TipoCandidato {
  REGULAR
  EXTERNO
}

enum TipoCertificado {
  CONCLUSAO
  PROFICIENCIA_PARCIAL
}

model Usuario {
  id              String      @id @default(uuid()) @map("id_usuario")
  nome            String      @db.VarChar(200)
  email           String?     @unique
  cpf             String      @unique @db.Char(11)
  senhaHash       String      @map("senha_hash")
  senhaProvisoria Boolean     @default(true) @map("senha_provisoria")
  tipo            TipoUsuario @default(ALUNO)
  ativo           Boolean     @default(true)
  criadoEm        DateTime    @default(now()) @map("criado_em")
  atualizadoEm    DateTime    @updatedAt @map("atualizado_em")
  tipoCandidato       TipoCandidato @default(REGULAR) @map("tipo_candidato")
  prereqValidado      Boolean       @default(false) @map("prereq_validado")
  prereqDocumento     String?       @map("prereq_documento")
  prereqValidadoPorId String?       @map("prereq_validado_por")
  prereqValidadoEm    DateTime?     @map("prereq_validado_em")

  aluno                 Aluno?
  professor             Professor?
  tokens                TokenAcesso[]
  notificacoesRecebidas Notificacao[]
  logsAcesso            LogAcesso[]
  administracoesEscola  AdministradorEscola[]

  @@map("usuarios")
}

model TokenAcesso {
  id         String    @id @default(uuid()) @map("id_token")
  usuarioId  String    @map("id_usuario")
  usuario    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo       TipoToken
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiraEm   DateTime  @map("expira_em")
  revogadoEm DateTime? @map("revogado_em")
  criadoEm   DateTime  @default(now()) @map("criado_em")

  @@map("tokens_acesso")
}

model Aluno {
  id                  String   @id @default(uuid()) @map("id_aluno")
  usuarioId           String   @unique @map("id_usuario")
  usuario             Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  necessidadeEspecial Boolean  @default(false) @map("necessidade_especial")
  dataNascimento      DateTime @map("data_nascimento") @db.Date
  criadoEm            DateTime @default(now()) @map("criado_em")
  atualizadoEm        DateTime @updatedAt @map("atualizado_em")

  turmas          TurmaAluno[]
  resultados      ResultadoAluno[]
  simuladosLivres SimuladoLivre[]
  inscricoes      InscricaoAluno[]
  aproveitamentos AproveitamentoCandidato[]
  certificados    Certificado[]

  @@map("alunos")
}

model Professor {
  id            String   @id @default(uuid()) @map("id_professor")
  usuarioId     String   @unique @map("id_usuario")
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  especialidade String?
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  questoes  Questao[]
  simulados Simulado[]
  turmas ProfessorTurma[]

  @@map("professores")
}

model NivelEnsino {
  id           String   @id @default(uuid()) @map("id_nivel")
  nome         String
  descricao    String?  @db.Text
  ordem        Int      @default(0)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  modalidades      Modalidade[]
  componentesNivel NivelComponente[]
  simulados        Simulado[]
  aproveitamentos  AproveitamentoCandidato[]
  certificados     Certificado[]

  @@map("niveis_ensino")
}

model Modalidade {
  id           String      @id @default(uuid()) @map("id_modalidade")
  nivelId      String      @map("id_nivel")
  nivel        NivelEnsino @relation(fields: [nivelId], references: [id])
  nome         String      @db.VarChar(50)
  supletivo    Boolean     @default(false)
  ativo        Boolean     @default(true)
  criadoEm     DateTime    @default(now()) @map("criado_em")
  atualizadoEm DateTime    @updatedAt @map("atualizado_em")

  componentes ComponenteCurricular[]
  turmas      Turma[]

  @@map("modalidades")
}

model ComponenteCurricular {
  id           String     @id @default(uuid()) @map("id_componente")
  modalidadeId String     @map("id_modalidade")
  modalidade   Modalidade @relation(fields: [modalidadeId], references: [id])
  nome         String     @db.VarChar(100)
  codigo       String     @db.VarChar(20)
  ativo        Boolean    @default(true)
  questionsSubjectSlug String? @map("questions_subject_slug")
  criadoEm     DateTime   @default(now()) @map("criado_em")
  atualizadoEm DateTime   @updatedAt @map("atualizado_em")

  assuntos  Assunto[]
  questoes  Questao[]
  simulados Simulado[]
  niveisComponente NivelComponente[]
  aproveitamentos  AproveitamentoCandidato[]

  @@map("componentes_curriculares")
}

model Assunto {
  id           String               @id @default(uuid()) @map("id_assunto")
  componenteId String               @map("id_componente")
  componente   ComponenteCurricular @relation(fields: [componenteId], references: [id])
  nome         String
  ativo        Boolean              @default(true)
  criadoEm     DateTime             @default(now()) @map("criado_em")
  atualizadoEm DateTime             @updatedAt @map("atualizado_em")

  questoes Questao[]

  @@map("assuntos")
}

model Questao {
  id              String               @id @default(uuid()) @map("id_questao")
  professorId     String               @map("id_professor")
  professor       Professor            @relation(fields: [professorId], references: [id])
  componenteId    String               @map("id_componente")
  componente      ComponenteCurricular @relation(fields: [componenteId], references: [id])
  assuntoId       String               @map("id_assunto")
  assunto         Assunto              @relation(fields: [assuntoId], references: [id])
  tipo            TipoQuestao
  dificuldade     TipoDificuldade
  enunciado       String               @db.Text
  urlImagem       String?              @map("url_imagem")
  alternativas    Json
  respostaCorreta String               @map("resposta_correta") @db.Char(1)
  ativa           Boolean              @default(true)
  criadoEm        DateTime             @default(now()) @map("criado_em")
  atualizadoEm    DateTime             @updatedAt @map("atualizado_em")

  @@map("questoes")
}

model Escola {
  id           String   @id @default(uuid()) @map("id_escola")
  nome         String
  municipio    String
  inep         String   @unique @db.Char(8)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  turmas          Turma[]
  administradores AdministradorEscola[]

  @@map("escolas")
}

model Turma {
  id           String     @id @default(uuid()) @map("id_turma")
  escolaId     String     @map("id_escola")
  escola       Escola     @relation(fields: [escolaId], references: [id])
  modalidadeId String     @map("id_modalidade")
  modalidade   Modalidade @relation(fields: [modalidadeId], references: [id])
  nome         String
  anoLetivo    Int        @map("ano_letivo")

  alunos     TurmaAluno[]
  aplicacoes Aplicacao[]
  professores ProfessorTurma[]

  @@unique([escolaId, nome, anoLetivo])
  @@map("turmas")
}

model TurmaAluno {
  turmaId  String    @map("id_turma")
  turma    Turma     @relation(fields: [turmaId], references: [id])
  alunoId  String    @map("id_aluno")
  aluno    Aluno     @relation(fields: [alunoId], references: [id])
  entrouEm DateTime  @map("entrou_em") @db.Date
  saiuEm   DateTime? @map("saiu_em") @db.Date

  @@id([turmaId, alunoId])
  @@map("turmas_alunos")
}

model FaixaSerie {
  id         String @id @default(uuid()) @map("id_faixa")
  nome       String @db.VarChar(100)
  quantidade Int?

  simulados Simulado[]

  @@map("faixa_series")
}

model Simulado {
  id                   String               @id @default(uuid()) @map("id_simulado")
  professorId          String               @map("id_professor")
  professor            Professor            @relation(fields: [professorId], references: [id])
  componenteId         String               @map("id_componente")
  componente           ComponenteCurricular @relation(fields: [componenteId], references: [id])
  componenteIds        Json?                @map("componente_ids")
  faixaId              String?              @map("id_faixa")
  faixa                FaixaSerie?          @relation(fields: [faixaId], references: [id])
  titulo               String               @db.VarChar(200)
  descricao            String?              @db.Text
  tipo                 TipoSimulado         @default(SIMULADO)
  status               StatusSimulado       @default(RASCUNHO)
  qtdFacil             Int                  @default(0) @map("qtd_facil")
  qtdMedio             Int                  @default(0) @map("qtd_medio")
  qtdDificil           Int                  @default(0) @map("qtd_dificil")
  vagas                Int
  duracaoMinutos       Int                  @map("duracao_minutos")
  janelaInicio         DateTime             @map("janela_inicio")
  janelaFim            DateTime             @map("janela_fim")
  embaralharAlternativas Boolean            @default(false) @map("embaralhar_alternativas")
  questoesSelecionadas Json?                @map("questoes_selecionadas")
  geraCertificado      Boolean              @default(false) @map("gera_certificado")
  nivelEnsinoId        String?              @map("id_nivel")
  nivelEnsino          NivelEnsino?         @relation(fields: [nivelEnsinoId], references: [id])
  notaMinimaCertificacao Float?             @map("nota_minima_certificacao")
  criadoEm             DateTime             @default(now()) @map("criado_em")
  atualizadoEm         DateTime             @updatedAt @map("atualizado_em")

  aplicacoes Aplicacao[]
  resultados ResultadoAluno[]
  inscricoes InscricaoAluno[]

  @@map("simulados")
}

model Aplicacao {
  id         String          @id @default(uuid()) @map("id_aplicacao")
  simuladoId String          @map("id_simulado")
  simulado   Simulado        @relation(fields: [simuladoId], references: [id])
  turmaId    String          @map("id_turma")
  turma      Turma           @relation(fields: [turmaId], references: [id])
  dataInicio DateTime        @map("data_inicio")
  dataFim    DateTime        @map("data_fim")
  status     StatusAplicacao @default(AGENDADA)
  criadoEm   DateTime        @default(now()) @map("criado_em")

  resultados ResultadoAluno[]

  @@map("aplicacoes")
}

model ResultadoAluno {
  id              String          @id @default(uuid()) @map("id_resultado")
  simuladoId      String?         @map("id_simulado")
  simulado        Simulado?       @relation(fields: [simuladoId], references: [id])
  aplicacaoId     String?         @map("id_aplicacao")
  aplicacao       Aplicacao?      @relation(fields: [aplicacaoId], references: [id])
  alunoId         String          @map("id_aluno")
  aluno           Aluno           @relation(fields: [alunoId], references: [id])
  pontuacao       Float?
  statusResultado StatusResultado @default(EM_ANDAMENTO) @map("status_resultado")
  iniciadoEm      DateTime?       @map("iniciado_em")
  finalizadoEm    DateTime?       @map("finalizado_em")

  tentativasQuestoes TentativaQuestao[]
  violacoes          ViolacaoProva[]
  aproveitamentos    AproveitamentoCandidato[]

  @@map("resultados_alunos")
}

model ViolacaoProva {
  id          String         @id @default(uuid()) @map("id_violacao")
  resultadoId String         @map("id_resultado")
  resultado   ResultadoAluno @relation(fields: [resultadoId], references: [id], onDelete: Cascade)
  tipo        String
  detalhe     String?
  criadoEm    DateTime       @default(now()) @map("criado_em")

  @@map("violacoes_prova")
}

model TentativaQuestao {
  resultadoId              String         @map("id_resultado")
  resultado                ResultadoAluno @relation(fields: [resultadoId], references: [id], onDelete: Cascade)
  questaoId                String         @map("id_questao")
  enunciado                String         @db.Text
  urlImagem                String?        @map("url_imagem")
  alternativas             Json
  respostaCorreta          String         @map("resposta_correta") @db.Char(1)
  ordem                    Int
  alternativaMarcada       String?        @map("alternativa_marcada") @db.Char(1)
  alternativasEmbaralhadas Json?          @map("alternativas_embaralhadas")
  respondidoEm             DateTime?      @map("respondido_em")

  @@id([resultadoId, questaoId])
  @@map("tentativa_questoes")
}

model AdministradorEscola {
  id        String   @id @default(uuid()) @map("id_admin")
  escolaId  String   @map("id_escola")
  escola    Escola   @relation(fields: [escolaId], references: [id])
  usuarioId String   @map("id_usuario")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  cargo     String?  @db.VarChar(100)
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@unique([escolaId, usuarioId])
  @@map("administradores_escola")
}

model Notificacao {
  id             String            @id @default(uuid()) @map("id_notificacao")
  usuarioDestId  String            @map("id_usuario_dest")
  usuarioDest    Usuario           @relation(fields: [usuarioDestId], references: [id])
  tipo           String
  status         StatusNotificacao @default(PENDENTE)
  titulo         String
  mensagem       String
  referenciaId   String?           @map("referencia_id")
  referenciaTipo String?           @map("referencia_tipo")
  lidaEm         DateTime?         @map("lida_em")

  @@map("notificacoes")
}

model LogAcesso {
  id          String          @id @default(uuid()) @map("id_log")
  usuarioId   String?         @map("id_usuario")
  usuario     Usuario?        @relation(fields: [usuarioId], references: [id])
  cpfTentado  String?         @map("cpf_tentado") @db.Char(11)
  ipOrigem    String          @map("ip_origem") @db.VarChar(45)
  dispositivo String?         @db.Text
  resultado   ResultadoAcesso
  criadoEm    DateTime        @default(now()) @map("criado_em")

  @@map("log_acesso")
}

model ProfessorTurma {
  professorId String    @map("id_professor")
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  turmaId     String    @map("id_turma")
  turma       Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@id([professorId, turmaId])
  @@map("professores_turmas")
}

model ImportacaoAlunos {
  id           String           @id @default(uuid()) @map("id_importacao")
  arquivoNome  String           @map("arquivo_nome")
  status       StatusImportacao @default(PENDENTE)
  totalLinhas  Int              @default(0) @map("total_linhas")
  processadas  Int              @default(0)
  importados   Int              @default(0)
  ignorados    Int              @default(0)
  linhas       Json
  erros        Json             @default("[]")
  criadoEm     DateTime         @default(now()) @map("criado_em")
  atualizadoEm DateTime         @updatedAt @map("atualizado_em")

  @@map("importacoes_alunos")
}

model InscricaoAluno {
  simuladoId String   @map("id_simulado")
  simulado   Simulado @relation(fields: [simuladoId], references: [id])
  alunoId    String   @map("id_aluno")
  aluno      Aluno    @relation(fields: [alunoId], references: [id])
  inscritoEm DateTime @default(now()) @map("inscrito_em")

  @@id([simuladoId, alunoId])
  @@map("inscricoes_alunos")
}

model SimuladoLivre {
  id             String              @id @default(uuid()) @map("id_simulado_livre")
  alunoId        String              @map("id_aluno")
  aluno          Aluno               @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  titulo         String              @db.VarChar(200)
  componenteIds  Json                @map("componente_ids")
  duracaoMinutos Int                 @map("duracao_minutos")
  status         StatusSimuladoLivre @default(EM_ANDAMENTO)
  pontuacao      Float?
  iniciadoEm     DateTime            @default(now()) @map("iniciado_em")
  finalizadoEm   DateTime?           @map("finalizado_em")
  criadoEm       DateTime            @default(now()) @map("criado_em")

  itens ItemSimuladoLivre[]

  @@map("simulados_livres")
}

model ItemSimuladoLivre {
  simuladoLivreId    String        @map("id_simulado_livre")
  simuladoLivre      SimuladoLivre @relation(fields: [simuladoLivreId], references: [id], onDelete: Cascade)
  questaoId          String        @map("id_questao")
  enunciado          String?       @db.Text
  urlImagem          String?       @map("url_imagem")
  alternativas       Json?
  respostaCorreta    String?       @map("resposta_correta") @db.Char(1)
  assunto            String?
  dificuldade        String?
  ordem              Int
  alternativaMarcada String?       @map("alternativa_marcada") @db.Char(1)
  respondidoEm       DateTime?     @map("respondido_em")

  @@id([simuladoLivreId, questaoId])
  @@map("itens_simulado_livre")
}

model NivelComponente {
  nivelId      String               @map("id_nivel")
  nivel        NivelEnsino          @relation(fields: [nivelId], references: [id])
  componenteId String               @map("id_componente")
  componente   ComponenteCurricular @relation(fields: [componenteId], references: [id])
  obrigatorio  Boolean              @default(true)

  @@id([nivelId, componenteId])
  @@map("niveis_componentes")
}

model AproveitamentoCandidato {
  id            String               @id @default(uuid()) @map("id_aproveitamento")
  alunoId       String               @map("id_aluno")
  aluno         Aluno                @relation(fields: [alunoId], references: [id])
  componenteId  String               @map("id_componente")
  componente    ComponenteCurricular @relation(fields: [componenteId], references: [id])
  nivelId       String               @map("id_nivel")
  nivel         NivelEnsino          @relation(fields: [nivelId], references: [id])
  anoReferencia Int                  @map("ano_referencia")
  aprovado      Boolean              @default(true)
  notaObtida    Float                @map("nota_obtida")
  tentativaId   String               @map("id_resultado")
  tentativa     ResultadoAluno       @relation(fields: [tentativaId], references: [id])
  criadoEm      DateTime             @default(now()) @map("criado_em")

  @@unique([alunoId, componenteId, nivelId, anoReferencia])
  @@map("aproveitamentos_candidato")
}

model Certificado {
  id                   String          @id @default(uuid()) @map("id_certificado")
  alunoId              String          @map("id_aluno")
  aluno                Aluno           @relation(fields: [alunoId], references: [id])
  nivelId              String          @map("id_nivel")
  nivel                NivelEnsino     @relation(fields: [nivelId], references: [id])
  anoReferencia        Int             @map("ano_referencia")
  tipo                 TipoCertificado @default(CONCLUSAO)
  codigoVerificacao    String          @unique @map("codigo_verificacao")
  assinaturaHash       String          @map("assinatura_hash")
  componentesAprovados Json            @map("componentes_aprovados")
  emitidoEm            DateTime        @default(now()) @map("emitido_em")

  @@unique([alunoId, nivelId, anoReferencia, tipo])
  @@map("certificados")
}
model IpAutorizado {
  id           String   @id @default(uuid()) @map("id_ip_autorizado")
  ip           String   @db.VarChar(45)
  descricao    String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("ips_autorizados")
}